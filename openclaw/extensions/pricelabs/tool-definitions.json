  {
    "name": "pricelabs_get_overrides",
    "description": "Fetch active date-specific overrides (DSOs) for a listing. Shows price adjustments, min-stay rules, and check-in/check-out restrictions per date.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "listing_id": {
          "type": "string",
          "description": "The listing ID to fetch overrides for"
        },
        "pms": {
          "type": "string",
          "description": "PMS identifier (e.g., 'airbnb')"
        },
        "start_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Filter overrides starting from this date (YYYY-MM-DD)"
        },
        "end_date": {
          "$ref": "#/properties/start_date",
          "description": "Filter overrides up to this date (YYYY-MM-DD)"
        }
      },
      "required": [
        "listing_id",
        "pms"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    }
  },
  {
    "name": "pricelabs_set_overrides",
    "description": "Create or update date-specific overrides (DSOs) for a listing. DSOs have the HIGHEST priority in PriceLabs and override ALL other settings including min price. REQUIRES reason for audit trail.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "listing_id": {
          "type": "string",
          "description": "The listing ID to set overrides for"
        },
        "pms": {
          "type": "string",
          "description": "PMS identifier (e.g., 'airbnb')"
        },
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "The date for this override (YYYY-MM-DD)"
              },
              "price_type": {
                "type": "string",
                "enum": [
                  "fixed",
                  "percentage"
                ],
                "description": "Override price type: 'fixed' for absolute price, 'percentage' for percent adjustment (-75 to 500)"
              },
              "price_value": {
                "type": "number",
                "description": "Override price value: absolute price if 'fixed', percent adjustment if 'percentage'"
              },
              "currency": {
                "type": "string",
                "description": "Currency code (REQUIRED when price_type is 'fixed', must match PMS currency)"
              },
              "min_stay": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "description": "Minimum stay override (integer > 0)"
              },
              "check_in": {
                "type": "string",
                "pattern": "^[01]{7}$",
                "description": "Check-in day restriction (7-char binary Mon-Sun)"
              },
              "check_out": {
                "$ref": "#/properties/overrides/items/properties/check_in",
                "description": "Check-out day restriction (7-char binary Mon-Sun)"
              }
            },
            "required": [
              "date",
              "price_type",
              "price_value"
            ],
            "additionalProperties": false
          },
          "minItems": 1,
          "description": "Array of date-specific overrides to apply"
        },
        "reason": {
          "type": "string",
          "minLength": 10,
          "description": "Rationale for this override change (min 10 chars, required for audit trail)"
        }
      },
      "required": [
        "listing_id",
        "pms",
        "overrides",
        "reason"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "destructiveHint": true,
      "readOnlyHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    }
  },
  {
    "name": "pricelabs_delete_overrides",
    "description": "Delete date-specific overrides for specified dates. Removes DSO pricing and restores dynamic pricing for those dates. REQUIRES reason for audit trail.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "listing_id": {
          "type": "string",
          "description": "The listing ID to delete overrides from"
        },
        "pms": {
          "type": "string",
          "description": "PMS identifier (e.g., 'airbnb')"
        },
        "dates": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Date in YYYY-MM-DD format"
          },
          "minItems": 1,
          "description": "Array of dates to remove overrides for (YYYY-MM-DD format)"
        },
        "reason": {
          "type": "string",
          "minLength": 10,
          "description": "Rationale for deleting these overrides (min 10 chars, required for audit trail)"
        }
      },
      "required": [
        "listing_id",
        "pms",
        "dates",
        "reason"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
