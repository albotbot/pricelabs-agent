  {
    "name": "pricelabs_store_daily_snapshots",
    "description": "Store today's listing snapshots in the database for historical tracking. Call this during daily health checks after fetching all listings via pricelabs_get_listings.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "listing_id": {
                "type": "string",
                "description": "PriceLabs listing ID"
              },
              "pms": {
                "type": "string",
                "description": "PMS name (e.g., 'bookingsync')"
              },
              "name": {
                "type": "string",
                "description": "Listing display name"
              },
              "health_7_day": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "7-day health score"
              },
              "health_30_day": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "30-day health score"
              },
              "health_60_day": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "60-day health score"
              },
              "occupancy_next_30": {
                "anyOf": [
                  {
                    "type": [
                      "number",
                      "string"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Listing occupancy next 30 days (0-100, may be '43 %' string from API)"
              },
              "market_occupancy_next_30": {
                "anyOf": [
                  {
                    "type": [
                      "number",
                      "string"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Market occupancy next 30 days (0-100, may be '43 %' string from API)"
              },
              "occupancy_gap_pct": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Computed occupancy gap vs market (%)"
              },
              "revenue_past_7": {
                "anyOf": [
                  {
                    "type": [
                      "number",
                      "string"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Revenue in past 7 days (may be 'Fully Blocked' string from API)"
              },
              "stly_revenue_past_7": {
                "anyOf": [
                  {
                    "type": [
                      "number",
                      "string"
                    ]
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "STLY revenue for past 7 days (may be string from API)"
              },
              "revenue_vs_stly_pct": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Computed revenue vs STLY (%)"
              },
              "base_price": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Current base price"
              },
              "recommended_base_price": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "PriceLabs recommended base price"
              },
              "last_date_pushed": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "ISO timestamp of last price sync push"
              },
              "days_since_sync": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Computed days since last sync"
              },
              "is_stale_sync": {
                "type": [
                  "boolean",
                  "null"
                ],
                "description": "True if days_since_sync > 2"
              },
              "data_json": {
                "type": "string",
                "description": "Full listing JSON blob for future-proofing"
              }
            },
            "required": [
              "listing_id",
              "pms",
              "data_json"
            ],
            "additionalProperties": false
          },
          "description": "Array of listing snapshots to store"
        },
        "snapshot_date": {
          "type": "string",
          "description": "Override snapshot date (YYYY-MM-DD). Defaults to today."
        }
      },
      "required": [
        "snapshots"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    }
