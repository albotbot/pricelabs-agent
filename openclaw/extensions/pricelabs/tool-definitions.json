  {
    "name": "pricelabs_update_listings",
    "description": "Update base/min/max prices or tags for one or more listings. REQUIRES reason parameter for audit trail. This is a DESTRUCTIVE operation -- changes take effect immediately.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "listings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "PriceLabs listing ID (required)"
              },
              "pms": {
                "type": "string",
                "description": "PMS identifier (required, e.g., 'airbnb')"
              },
              "min": {
                "type": "number",
                "description": "New minimum nightly price"
              },
              "base": {
                "type": "number",
                "description": "New base price anchor"
              },
              "max": {
                "type": "number",
                "description": "New maximum nightly price"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "maxItems": 10,
                "description": "Listing tags (max 10 tags)"
              }
            },
            "required": [
              "id",
              "pms"
            ],
            "additionalProperties": false
          },
          "minItems": 1,
          "description": "Array of listing updates to apply"
        },
        "reason": {
          "type": "string",
          "minLength": 10,
          "description": "Rationale for this change (min 10 chars, required for audit trail)"
        }
      },
      "required": [
        "listings",
        "reason"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
