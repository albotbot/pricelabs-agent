# OpenClaw Gateway Environment Variables
# Copy this file to ~/.openclaw/.env and fill in the values.
# NEVER commit actual secrets to version control.

# --- Gateway Authentication ---
# Generate a secure random token: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# --- PriceLabs API ---
# PriceLabs Dashboard -> Settings -> API -> Generate API Key
PRICELABS_API_KEY=your-pricelabs-api-key-here

# --- Slack Channel ---
# Slack API -> Your App -> Basic Information -> App-Level Tokens
SLACK_APP_TOKEN=xapp-your-slack-app-token-here
# Slack API -> Your App -> OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# --- Telegram Channel ---
# Telegram BotFather -> /newbot -> copy token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
